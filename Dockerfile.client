FROM node:22-alpine AS deps
WORKDIR /app
RUN npm install --omit=dev --no-fund --no-audit --no-package-lock express@^5.2.1

FROM node:22-alpine AS runtime
ENV NODE_ENV=production
WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY apps/client/static-client-server.js ./
COPY dist/apps/client/browser ./steam-idler-client-dist

RUN chown -R node:node /app

USER node

EXPOSE 2222

CMD ["node", "static-client-server.js"]
