{
  "name": "@steam-idler/source",
  "version": "2.0.0",
  "license": "MIT",
  "author": "Konstantine datunishvili",
  "scripts": {
    "prepare": "husky",
    "start": "nx run client:serve-with-server",
    "start:client": "nx serve client",
    "start:server": "nx serve server",
    "build": "nx run-many --target=build --all",
    "build:client": "nx build client",
    "build:server": "nx build server",
    "release": "commit-and-tag-version",
    "release:patch": "commit-and-tag-version --release-as patch",
    "release:minor": "commit-and-tag-version --release-as minor",
    "release:major": "commit-and-tag-version --release-as major",
    "lint": "nx affected -t lint --parallel=3",
    "lint:all": "nx run-many -t lint --parallel=3",
    "lint:fix": "nx affected -t lint --parallel=3 --fix",
    "lint:fix:all": "nx run-many -t lint --parallel=3 --fix",
    "db:up": "docker compose -f docker-compose.dev.yml up -d",
    "db:down": "docker compose -f docker-compose.dev.yml down",
    "g:secret": "node -e \"console.log(require('crypto').randomBytes(64).toString('hex'))\"",
    "docker:build:client": "pnpm build:client && docker build --no-cache -f Dockerfile.client -t kostad02/steam-idler-client:$npm_package_version .",
    "docker:build:server": "pnpm build:server && docker build --no-cache -f Dockerfile.server -t kostad02/steam-idler-server:$npm_package_version .",
    "docker:build": "pnpm run docker:build:client && pnpm run docker:build:server",
    "docker:local:up": "pnpm db:down && pnpm build && docker compose -f docker-compose.local.yml up --build --attach steam-idler-server --attach steam-idler-client",
    "docker:local:down": "docker compose -f docker-compose.local.yml down"
  },
  "private": true,
  "lint-staged": {
    "*.{ts,tsx,js,jsx,cjs,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,html,css,scss}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@angular/common": "~21.2.14",
    "@angular/compiler": "~21.2.14",
    "@angular/core": "~21.2.14",
    "@angular/forms": "~21.2.14",
    "@angular/platform-browser": "~21.2.14",
    "@angular/platform-browser-dynamic": "~21.2.14",
    "@angular/router": "~21.2.14",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.4.2",
    "@types/bcrypt": "^6.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/steam-user": "^5.1.1",
    "axios": "^1.16.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "mongoose": "^9.5.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "passport-strategy": "^1.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "steam-user": "^5.3.0"
  },
  "devDependencies": {
    "@angular-devkit/core": "~21.2.12",
    "@angular-devkit/schematics": "~21.2.12",
    "@angular/build": "~21.2.12",
    "@angular/cli": "~21.2.12",
    "@angular/compiler-cli": "~21.2.14",
    "@angular/language-service": "~21.2.14",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@eslint/js": "^10.0.1",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/angular": "^22.7.1",
    "@nx/devkit": "22.6.5",
    "@nx/eslint": "22.7.1",
    "@nx/eslint-plugin": "22.7.1",
    "@nx/jest": "22.7.1",
    "@nx/js": "22.7.1",
    "@nx/nest": "22.6.5",
    "@nx/node": "22.7.1",
    "@nx/playwright": "22.7.1",
    "@nx/plugin": "22.7.1",
    "@nx/web": "22.7.1",
    "@nx/webpack": "22.7.1",
    "@nx/workspace": "22.7.1",
    "@playwright/test": "^1.36.0",
