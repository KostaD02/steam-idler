# NestJS runtime config (loaded by @nestjs/config).
# Copy to `apps/server/.env` and adjust as needed.

SERVER_PORT=3000
SERVER_LOG_ENABLED=true
JWT_EXPIRES_IN=1

# You can generate secret with "pnpm g:secret" command
JWT_SECRET=REPLACE_ME_WITH_SECRET

# Steam-idler's MongoDB is exposed on host port 27018 (see docker-compose.dev.yml)
# to avoid clashing with other local mongo instances on the default 27017.
DATABASE_URL=mongodb://127.0.0.1:27018/steam-idler
